<odoo>

    <!-- Muestra todas las universidades en formato de tarjetas -->
    <template id="university_list_template" name="University List">
        <!-- Usamos el layout general del sitio web -->
        <t t-call="website.layout">

            <div class="container mt-4">

                <!-- Título principal de la página -->
                <h1 class="mb-4 text-center">Our Universities</h1>

                <div class="row">

                    <!-- Recorremos todas las universidades enviadas desde el controlador -->
                    <t t-foreach="universities" t-as="univ">

                        <div class="col-md-4 mb-4">
                            <div class="card h-100 shadow-sm">

                                <!-- Imagen de la universidad -->
                                <img t-attf-src="/web/image/university.university/#{univ.id}/image_1920"
                                     class="card-img-top"
                                     style="height: 200px; object-fit: cover;"/>

                                <div class="card-body text-center">

                                    <!-- Nombre de la universidad -->
                                    <h5 class="card-title" t-field="univ.name"/>

                                    <!-- Botón que lleva a la lista de profesores de esa universidad -->
                                    <a t-attf-href="/profesores/#{univ.id}" class="btn btn-primary">
                                        View Professors
                                    </a>

                                </div>
                            </div>
                        </div>

                    </t>

                </div>
            </div>

        </t>
    </template>


    <!-- Muestra los profesores asociados a una universidad concreta -->
    <template id="professor_list_template" name="Professor List">
        <t t-call="website.layout">

            <div class="container mt-4">

                <!-- Encabezado con el nombre de la universidad -->
                <div class="text-center mb-5">
                    <h1 t-field="university.name"/>
                    <p class="text-muted">Teaching Staff</p>
                </div>

                <div class="row justify-content-center">

                    <!-- Recorremos todos los profesores enviados desde el controlador -->
                    <t t-foreach="professors" t-as="prof">

                        <div class="col-md-3 mb-4 text-center">

                            <!-- Foto del profesor -->
                            <img t-attf-src="/web/image/university.professor/#{prof.id}/image_1920"
                                 class="rounded-circle shadow"
                                 style="width: 150px; height: 150px; object-fit: cover;"/>

                            <!-- Nombre del profesor -->
                            <h5 class="mt-3" t-field="prof.name"/>

                        </div>

                    </t>

                </div>

                <!-- Botón para volver a la lista de universidades -->
                <div class="text-center mt-4">
                    <a href="/universidad" class="btn btn-outline-secondary">
                        Back to Universities
                    </a>
                </div>

            </div>

        </t>
    </template>

</odoo>
