<odoo>

    <!-- Se usan para enlazar los menús con las pantallas -->

    <!-- Acción para gestionar Universidades -->
    <record id="action_university_university" model="ir.actions.act_window">
        <field name="name">Universities</field>
        <field name="res_model">university.university</field>
        <field name="view_mode">list,kanban,form</field>
    </record>

    <!-- Acción para gestionar Departamentos -->
    <record id="action_university_department" model="ir.actions.act_window">
        <field name="name">Departments</field>
        <field name="res_model">university.department</field>
        <field name="view_mode">list,kanban,form</field>
    </record>

    <!-- Acción para gestionar Profesores -->
    <record id="action_university_professor" model="ir.actions.act_window">
        <field name="name">Professors</field>
        <field name="res_model">university.professor</field>
        <field name="view_mode">list,kanban,form</field>
    </record>

    <!-- Acción para gestionar Asignaturas -->
    <record id="action_university_subject" model="ir.actions.act_window">
        <field name="name">Subjects</field>
        <field name="res_model">university.subject</field>
        <field name="view_mode">list,kanban,form</field>
    </record>

    <!-- Acción para gestionar Estudiantes -->
    <record id="action_university_student" model="ir.actions.act_window">
        <field name="name">Students</field>
        <field name="res_model">university.student</field>
        <field name="view_mode">list,kanban,form</field>
    </record>

    <!-- Acción para gestionar Matrículas -->
    <record id="action_university_enrollment" model="ir.actions.act_window">
        <field name="name">Enrollments</field>
        <field name="res_model">university.enrollment</field>
        <field name="view_mode">list,kanban,form</field>
    </record>

    <!-- Acción para gestionar Notas -->
    <record id="action_university_grade" model="ir.actions.act_window">
        <field name="name">Grades</field>
        <field name="res_model">university.grade</field>
        <field name="view_mode">list,kanban,form</field>
    </record>


    <!-- El menú raíz agrupa todos los submenús del módulo -->

    <!-- Menú raíz del módulo University -->
    <menuitem id="menu_university_root" name="University" sequence="10"/>

    <!-- Submenú: Universidades -->
    <menuitem id="menu_university_universities"
              parent="menu_university_root"
              name="Universities"
              action="action_university_university"
              sequence="10"/>

    <!-- Submenú: Departamentos -->
    <menuitem id="menu_university_departments"
              parent="menu_university_root"
              name="Departments"
              action="action_university_department"
              sequence="20"/>

    <!-- Submenú: Profesores -->
    <menuitem id="menu_university_professors"
              parent="menu_university_root"
              name="Professors"
              action="action_university_professor"
              sequence="30"/>

    <!-- Submenú: Asignaturas -->
    <menuitem id="menu_university_subjects"
              parent="menu_university_root"
              name="Subjects"
              action="action_university_subject"
              sequence="40"/>

    <!-- Submenú: Estudiantes -->
    <menuitem id="menu_university_students"
              parent="menu_university_root"
              name="Students"
              action="action_university_student"
              sequence="50"/>

    <!-- Submenú: Matrículas -->
    <menuitem id="menu_university_enrollments"
              parent="menu_university_root"
              name="Enrollments"
              action="action_university_enrollment"
              sequence="60"/>

    <!-- Submenú: Notas -->
    <menuitem id="menu_university_grades"
              parent="menu_university_root"
              name="Grades"
              action="action_university_grade"
              sequence="70"/>

</odoo>