<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_delivery_document_pretty_centered" inherit_id="stock.report_delivery_document">
        <xpath expr="//div[@class='page']" position="before">
            <style>
                .address, .information_block { display: none !important; }
            </style>
            <table style="width: 100%; border-collapse: separate; border-spacing: 10px; margin-bottom: 20px;">
                <tr>
                    <td style="width: 50%; border: 2px solid #875A7B; border-radius: 12px; padding: 15px; background-color: #fdfdfd; vertical-align: top;">
                        <strong style="color: #875A7B; display: block; border-bottom: 2px solid #875A7B; margin-bottom: 10px; font-size: 14px;">DIRECCIÓN DEL CLIENTE</strong>
                        <div t-field="o.partner_id" t-options='{"widget": "contact", "fields": ["address", "name", "phone"], "no_marker": True}'/>
                    </td>
                    <td style="width: 50%; border: 2px solid #875A7B; border-radius: 12px; padding: 15px; background-color: #fdfdfd; vertical-align: top;">
                        <strong style="color: #875A7B; display: block; border-bottom: 2px solid #875A7B; margin-bottom: 10px; font-size: 14px;">DIRECCIÓN DE ENTREGA</strong>
                        <div t-if="o.move_ids and o.move_ids[0].partner_id" t-field="o.move_ids[0].partner_id" t-options='{"widget": "contact", "fields": ["address", "name", "phone"], "no_marker": True}'/>
                        <div t-else="" t-field="o.partner_id" t-options='{"widget": "contact", "fields": ["address", "name", "phone"], "no_marker": True}'/>
                    </td>
                </tr>
            </table>
        </xpath>
        <xpath expr="//table[hasclass('table')]" position="after">
            <div t-if="o.x_notes" style="margin-top: 20px; width: 100%; page-break-inside: avoid;">
                <table style="width: 100%; border: 2px solid #875A7B; border-collapse: separate; border-radius: 10px;">
                    <thead><tr><th style="background-color: #875A7B; color: white; padding: 10px; text-align: center;">NOTAS DEL PEDIDO DE VENTA</th></tr></thead>
                    <tbody><tr><td style="padding: 15px; background-color: #f9f9f9;"><span t-field="o.x_notes"/></td></tr></tbody>
                </table>
            </div>
        </xpath>
    </template>

    <template id="report_picking_pretty_centered" inherit_id="stock.report_picking">
        <xpath expr="//table[hasclass('table')]" position="before">
            <style>
                /* Ocultamos todo lo que Odoo pone arriba por defecto para que no se duplique */
                .address, div[name="partner_header"], .row.mt48, div[name="customer_address"] { 
                    display: none !important; 
                }
            </style>
            
            <table style="width: 100%; border-collapse: separate; border-spacing: 0 10px; margin-bottom: 15px; font-size: 13px;">
                <tr>
                    <td style="width: 48%; border: 2px solid #875A7B; border-radius: 12px; padding: 12px; vertical-align: top;">
                        <strong style="color: #875A7B; display: block; border-bottom: 1px solid #875A7B; margin-bottom: 8px;">DIRECCIÓN DE ENTREGA</strong>
                        <div t-if="o.move_ids and o.move_ids[0].partner_id" t-field="o.move_ids[0].partner_id" t-options='{"widget": "contact", "fields": ["address", "name", "phone"], "no_marker": True}'/>
                        <div t-else="" t-field="o.partner_id" t-options='{"widget": "contact", "fields": ["address", "name", "phone"], "no_marker": True}'/>
                    </td>
                    <td style="width: 4%;"></td>
                    <td style="width: 48%; border: 2px solid #875A7B; border-radius: 12px; padding: 12px; vertical-align: top;">
                        <strong style="color: #875A7B; display: block; border-bottom: 1px solid #875A7B; margin-bottom: 8px;">DATOS DEL PREPARADOR</strong>
                        <strong>Cliente: </strong> <span t-field="o.partner_id.name"/><br/>
                        <strong>Orden: </strong> <span t-field="o.origin"/><br/>
                        <strong>Almacén: </strong> <span t-field="o.picking_type_id.warehouse_id.name"/>
                    </td>
                </tr>
            </table>
        </xpath>

        <xpath expr="//table[hasclass('table')]" position="after">
            <div t-if="o.x_notes" style="margin-top: 15px; width: 100%; page-break-inside: avoid;">
                <table style="width: 100%; border: 2px solid #875A7B; border-collapse: separate; border-radius: 10px;">
                    <thead><tr><th style="background-color: #875A7B; color: white; padding: 8px; text-align: center;">NOTAS PARA EL ALMACÉN</th></tr></thead>
                    <tbody><tr><td style="padding: 10px; background-color: #fdfdfd; font-size: 13px;"><span t-field="o.x_notes"/></td></tr></tbody>
                </table>
            </div>
        </xpath>
    </template>
</odoo>